JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
SETUP_SECRET=change-me-to-a-random-string-at-least-32-chars
DATABASE_URL=postgres://orkai:orkai@localhost:5433/orkai?sslmode=disable
SERVER_PORT=8080
# Local dev (make docker-up): path relative to apps/api
KUBECONFIG=../../deploy/kubeconfig/kubeconfig.yaml
K8S_IN_CLUSTER=false
# Production install uses /etc/rancher/k3s/k3s.yaml instead

# Sentry (optional — leave empty to disable)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
